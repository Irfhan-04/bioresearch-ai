# BioResearch AI — 9 environment variables required.
# ANTHROPIC_API_KEY is optional. The system runs with 3/4 AI components without it.

DATABASE_URL=postgresql+asyncpg://user:pass@host/db
REDIS_URL=redis://default:password@host:port
PUBMED_EMAIL=your@email.com
PUBMED_API_KEY=optional_ncbi_key
ANTHROPIC_API_KEY=optional_for_component_3_llm_intelligence
OPENAI_API_KEY=optional_fallback
SECRET_KEY=run_uv_run_python_-c_import_secrets_print_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=false
LOG_LEVEL=INFO
